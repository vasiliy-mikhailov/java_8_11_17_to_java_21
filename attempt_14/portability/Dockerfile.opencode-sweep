# Maven-augmented opencode/kilocode sweep base: portability container + system Maven 3.9.9
# (so wrapper-less repos build). Used for the P12 cross-agent validation, not the P11 cold witness.
FROM bump-portability:latest
RUN curl -fsSL https://archive.apache.org/dist/maven/maven-3/3.9.9/binaries/apache-maven-3.9.9-bin.tar.gz \
    | tar xz -C /opt && ln -sf /opt/apache-maven-3.9.9/bin/mvn /usr/local/bin/mvn
