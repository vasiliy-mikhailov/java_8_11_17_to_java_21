+        if (issuedVal instanceof String) {
+            // Case1 (issued is a String): "issued": "YYYY"
+            this.issued = (String) issuedVal;
+        } else if (issuedVal instanceof List) {
+            // Case2 (issued is a List of String): "issued": ["YYYY"]
