diff --git a/api-gateway/src/main/resources/application.properties b/api-gateway/src/main/resources/application.properties
index 292ca05..d3433f1 100644
--- a/api-gateway/src/main/resources/application.properties
+++ b/api-gateway/src/main/resources/application.properties
@@ -1 +1,38 @@
 spring.application.name=api-gateway
+server.port=8080
+
+# ---- Rutas del Gateway ----
+
+# ms-user-auth → /api/auth/**
+spring.cloud.gateway.mvc.routes[0].id=ms-user-auth
+spring.cloud.gateway.mvc.routes[0].uri=${USER_AUTH_URL:http://localhost:8084}
+spring.cloud.gateway.mvc.routes[0].predicates[0]=Path=/api/auth/**
+
+# ms-pet-management → /api/pets/**
+spring.cloud.gateway.mvc.routes[1].id=ms-pet-management
+spring.cloud.gateway.mvc.routes[1].uri=${PET_MANAGEMENT_URL:http://localhost:8081}
+spring.cloud.gateway.mvc.routes[1].predicates[0]=Path=/api/pets/**
+
+# ms-geolocation → /api/locations/**
+spring.cloud.gateway.mvc.routes[2].id=ms-geolocation
+spring.cloud.gateway.mvc.routes[2].uri=${GEOLOCATION_URL:http://localhost:8082}
+spring.cloud.gateway.mvc.routes[2].predicates[0]=Path=/api/locations/**
+
+# ms-matching-engine → /api/matches/**
+spring.cloud.gateway.mvc.routes[3].id=ms-matching-engine
+spring.cloud.gateway.mvc.routes[3].uri=${MATCHING_ENGINE_URL:http://localhost:8083}
+spring.cloud.gateway.mvc.routes[3].predicates[0]=Path=/api/matches/**
+
+# ms-notification → /api/notifications/**
+spring.cloud.gateway.mvc.routes[4].id=ms-notification
+spring.cloud.gateway.mvc.routes[4].uri=${NOTIFICATION_URL:http://localhost:8085}
+spring.cloud.gateway.mvc.routes[4].predicates[0]=Path=/api/notifications/**
+
+# bff → /api/bff/**
+spring.cloud.gateway.mvc.routes[5].id=bff
+spring.cloud.gateway.mvc.routes[5].uri=${BFF_URL:http://localhost:8086}
+spring.cloud.gateway.mvc.routes[5].predicates[0]=Path=/api/bff/**
+
+# ---- Actuator ----
+management.endpoints.web.exposure.include=health,info
+management.endpoint.health.show-details=always
