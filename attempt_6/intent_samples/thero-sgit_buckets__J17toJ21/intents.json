        "before": "<maven.compiler.release>17</maven.compiler.release>",
        "after": "<maven.compiler.release>21</maven.compiler.release>",
        "kind": "update_compiler_target",
        "bucket": "breaking"
      },
      {
        "general_idea": "Replace the JUnit BOM import with a direct dependency on the junit-jupiter aggregate artifact to simplify dependency management.",
        "why_exists": "",
        "before": "<dependency>\n        <groupId>org.junit</groupId>\n        <artifactId>junit-bom</artifactId>\n        <version>5.11.0</version>\n        <type>pom</type>\n        <scope>import</scope>\n      </dependency>",
        "after": "<dependency>\n            <groupId>org.junit.jupiter</groupId>\n            <artifactId>junit-jupiter</artifactId>\n            <version>5.10.2</version>\n            <scope>test</scope>\n        </dependency>",
        "kind": "simplify_test_dependencies",
        "bucket": "polishment"
      },
      {
        "general_idea": "Remove explicit version locking for standard Maven lifecycle plugins (clean, resources, jar, etc.) in favor of default or parent-managed versions.",
