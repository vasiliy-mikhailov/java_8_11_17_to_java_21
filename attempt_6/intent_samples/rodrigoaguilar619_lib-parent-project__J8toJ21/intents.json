    "pom.xml": [
      {
        "general_idea": "Upgrade Spring Boot parent from 2.3.0 to 3.2.0 to support Java 21 and modern Spring ecosystem.",
        "why_exists": "Spring Boot 2.x does not support Java 21; Spring Boot 3.x requires Java 17+ and uses Jakarta EE namespace instead of Java EE, causing compile failures if not upgraded.",
        "before": "<parent>\n\t\t<groupId>org.springframework.boot</groupId>\n\t\t<artifactId>spring-boot-starter-parent</artifactId>\n\t\t<version>2.3.0.RELEASE</version>",
        "after": "<parent>\n\t\t<groupId>org.springframework.boot</groupId>\n\t\t<artifactId>spring-boot-starter-parent</artifactId>\n\t\t<version>3.2.0</version>",
        "kind": "upgrade_spring_boot_parent",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update Java version property from 1.8 to 21 to target the new JDK.",
        "why_exists": "Compiling with Java 8 settings on a Java 21 JDK or vice-versa causes incompatibility; Spring Boot 3 requires Java 17+.",
        "before": "<java.version>1.8</java.version>",
        "after": "<java.version>21</java.version>",
        "kind": "update_java_version_property",
        "bucket": "breaking"
      },
      {
        "general_idea": "Replace legacy MySQL connector artifact with the new MySQL Connector/J artifact.",
        "why_exists": "The artifact 'mysql:mysql-connector-java' is deprecated and removed in newer versions; 'com.mysql:mysql-connector-j' is required for compatibility with Spring Boot 3 and Java 21.",
        "before": "<dependency>\n\t\t\t<groupId>mysql</groupId>\n\t\t\t<artifactId>mysql-connector-java</artifactId>",
        "after": "<dependency>\n\t\t    <groupId>com.mysql</groupId>\n\t\t    <artifactId>mysql-connector-j</artifactId>",
        "kind": "replace_mysql_connector_artifact",
        "bucket": "breaking"
      },
