    "pom.xml": [
      {
        "general_idea": "Upgrade Spring Boot parent version to 3.1.0 to support Java 17 and modern Spring ecosystem.",
        "why_exists": "Spring Boot 2.x does not support Java 17 as a baseline and lacks compatibility with Spring Framework 6 APIs required for modern reactive stacks.",
        "before": "<version>2.2.7.RELEASE</version>",
        "after": "<version>3.1.0</version>",
        "kind": "upgrade_spring_boot_parent",
        "bucket": "breaking"
      },
