    "pom.xml": [
      {
        "general_idea": "Update the Maven compiler release property from Java 11 to Java 17 to target the new JDK version.",
        "why_exists": "Without this change, the project compiles against Java 11 APIs and bytecode, failing to utilize Java 17 features or meeting the migration requirement.",
        "before": "<maven.compiler.release>11</maven.compiler.release>",
        "after": "<maven.compiler.release>17</maven.compiler.release>",
        "kind": "update_compiler_target",
        "bucket": "breaking"
      },
      {
        "general_idea": "Explicitly define the maven-compiler-plugin version to ensure support for the maven.compiler.release property.",
        "why_exists": "The default maven-compiler-plugin version in older Maven distributions (e.g., 3.1) does not support the 'release' flag, causing a build failure.",
        "before": "",
        "after": "<plugin><artifactId>maven-compiler-plugin</artifactId><version>3.8.1</version></plugin>",
        "kind": "add_compiler_plugin_version",
        "bucket": "breaking"
      },
      {
        "general_idea": "Remove deprecated maven.compiler.source and maven.compiler.target properties in favor of maven.compiler.release.",
        "why_exists": "Using source/target alongside release can cause conflicts or warnings; release is the preferred modern approach for cross-compilation.",
        "before": "<maven.compiler.source>11</maven.compiler.source>\n<maven.compiler.target>11</maven.compiler.target>",
        "after": "",
        "kind": "remove_deprecated_compiler_props",
        "bucket": "polishment"
      },
      {
        "general_idea": "Replace individual JUnit dependencies with the JUnit BOM for better version management.",
        "why_exists": "Managing individual JUnit module versions manually is error-prone; the BOM ensures consistent versions across all JUnit modules.",
        "before": "<dependency><groupId>org.junit.jupiter</groupId><artifactId>junit-jupiter-engine</artifactId><version>5.6.0</version></dependency>",
        "after": "<dependency><groupId>org.junit</groupId><artifactId>junit-bom</artifactId><version>5.8.1</version><type>pom</type><scope>import</scope></dependency>",
        "kind": "use_junit_bom",
        "bucket": "polishment"
      },
      {
