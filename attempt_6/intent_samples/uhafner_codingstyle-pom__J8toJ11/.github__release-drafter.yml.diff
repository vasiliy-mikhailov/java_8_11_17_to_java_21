diff --git a/.github/release-drafter.yml b/.github/release-drafter.yml
index 242763b..84d0727 100644
--- a/.github/release-drafter.yml
+++ b/.github/release-drafter.yml
@@ -1,42 +1,56 @@
-tag-template: codingstyle-$NEXT_PATCH_VERSION
-name-template: Codingstyle $NEXT_PATCH_VERSION 🎁
+name-template: 'v$RESOLVED_VERSION 🎁'
+tag-template: 'v$RESOLVED_VERSION'
 
-version-template: $MAJOR.$MINOR.$PATCH
+template: |
+  $CHANGES
 
 # Emoji reference: https://gitmoji.carloscuesta.me/
 categories:
-  - title: 🚨 Removed
+  - title: 💥 Removed
     label: removed
   - title: ⚠️ Deprecated
     label: deprecated
-  - title: 🚀 New features and improvements
+  - title: 🚀 New Features
     labels:
-      - enhancement
       - feature
+  - title: ✨ Improvements
+    labels:
+      - enhancement
   - title: 🐛 Bug Fixes
     labels:
       - bug
       - fix
       - bugfix
       - regression
-  - title: 📝 Documentation updates
+  - title: 📝 Documentation Updates
     label: documentation
-  - title: 📦 Dependency updates
+  - title: 📦 Dependency Updates
     label: dependencies
-  - title: 🔧 Internal changes
+  - title: 🔧 Internal Changes
     label: internal
   - title: 🚦 Tests
     labels:
       - test
       - tests
 
-exclude-labels:
-  - reverted
-  - no-changelog
-  - skip-changelog
-  - invalid
-
-template: |
-  # Changelog
+version-resolver:
+  major:
+    labels:
+      - 'removed'
+  minor:
+    labels:
+      - 'feature'
+      - 'enhancement'
+      - 'deprecated'
+      - 'dependencies'
+      - 'documentation'
+      - 'tests'
+      - 'internal'
+  patch:
+    labels:
+      - 'bug'
+  default: minor
 
-  $CHANGES
+replacers:
+  - search: '/\[*JENKINS-(\d+)\]*\s*-*\s*/g'
+    replace: '[JENKINS-$1](https://issues.jenkins.io/browse/JENKINS-$1) - '
