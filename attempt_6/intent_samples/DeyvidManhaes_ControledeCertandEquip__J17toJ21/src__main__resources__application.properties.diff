+# Configuração do Hibernate
+spring.jpa.hibernate.ddl-auto=validate
+# A opção "validate" verifica se o modelo de dados corresponde ao banco. Alternativas: create, update, none.
+# use "update" se desejar que o Hibernate crie ou atualize a estrutura automaticamente, mas "validate" é mais seguro em produção.
+# Habilita o Flyway para migrações automáticas de banco de dados
+spring.flyway.enabled=true
+spring.flyway.schemas=public
+
+# Configuração de acesso ao banco de dados para Flyway
+spring.flyway.url=jdbc:postgresql://localhost:5432/db_control
+spring.flyway.user=postgres
+spring.flyway.password=123456
+
+# Localização dos scripts de migração
+spring.flyway.locations=classpath:db/migration
+
+# Caso o banco de dados já tenha sido criado sem o Flyway, o baseline inicial é feito automaticamente.
+spring.flyway.baseline-on-migrate=true
