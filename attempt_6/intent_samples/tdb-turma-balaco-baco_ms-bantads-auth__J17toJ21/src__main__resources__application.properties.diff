+# Migrations
+spring.flyway.enabled=true
+
+# JPA Configuration
+spring.jpa.hibernate.ddl-auto=none
+spring.jpa.show-sql=false
+
+# Logging Levels
+logging.level.root=info
+logging.level.sql=debug
