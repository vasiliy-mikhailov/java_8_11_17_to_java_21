    "src/main/java/h2/orm/core/EntityManagerProvider.java": [
      {
        "general_idea": "Remove ThreadLocal EntityManager caching to adopt a per-transaction EntityManager lifecycle pattern.",
        "why_exists": "",
        "before": "private static final ThreadLocal<EntityManager> entityManagerThreadLocal = new ThreadLocal<>();",
        "after": "",
        "kind": "remove_thread_local_cache",
        "bucket": "polishment"
      },
      {
        "general_idea": "Refactor getEntityManager to create a new EntityManager instance on every call instead of retrieving from ThreadLocal.",
        "why_exists": "",
        "before": "EntityManager em = entityManagerThreadLocal.get();\nif (em == null || !em.isOpen()) {\n    EntityManagerFactory factory = factories.get(configName);\n    if (factory == null) {\n        throw new DatabaseNotInitializedException();\n    }\n    em = factory.createEntityManager();\n    entityManagerThreadLocal.set(em);\n}\nreturn em;",
        "after": "EntityManagerFactory factory = factories.get(configName);\nif (factory == null) {\n    throw new DatabaseNotInitializedException();\n}\nreturn factory.createEntityManager();",
        "kind": "refactor_get_entity_manager",
        "bucket": "polishment"
      },
      {
        "general_idea": "Deprecate closeEntityManager by removing ThreadLocal cleanup logic, as EntityManagers are now short-lived.",
        "why_exists": "",
        "before": "EntityManager em = entityManagerThreadLocal.get();\nif (em != null && em.isOpen()) {\n    try {\n        if (em.getTransaction().isActive()) {\n            em.getTransaction().rollback();\n        }\n        em.close();\n    } catch (Exception e) {\n        logger.warn(\"Error closing EntityManager\", e);\n    } finally {\n        entityManagerThreadLocal.remove();\n    }\n}",
        "after": "// This method is now deprecated since we create fresh EntityManagers per transaction\n// Left for backward compatibility but does nothing\nlogger.debug(\"closeEntityManager() called - no operation needed with current transaction model\");",
        "kind": "deprecate_close_entity_manager",
        "bucket": "polishment"
      },
      {
        "general_idea": "Update executeInTransaction to manually manage EntityManager lifecycle (create, use, close) instead of relying on ThreadLocal state.",
        "why_exists": "",
        "before": "EntityManager em = getEntityManager(configName);\ntry {\n    em.getTransaction().begin();\n    T result = callback.execute(em);\n    em.getTransaction().commit();\n    return result;\n} catch (Exception e) {\n    if (em.getTransaction().isActive()) {\n        em.getTransaction().rollback();\n    }\n    throw new RuntimeException(\"Transaction failed\", e);\n} finally {\n    closeEntityManager();\n}",
        "after": "EntityManager em = null;\ntry {\n    EntityManagerFactory factory = factories.get(configName);\n    if (factory == null) {\n        throw new DatabaseNotInitializedException();\n    }\n    em = factory.createEntityManager();\n    em.getTransaction().begin();\n    T result = callback.execute(em);\n    em.getTransaction().commit();\n    return result;\n} catch (Exception e) {\n    if (em != null && em.getTransaction().isActive()) {\n        em.getTransaction().rollback();\n    }\n    throw new RuntimeException(\"Transaction failed\", e);\n} finally {\n    if (em != null && em.isOpen()) {\n        em.close();\n    }\n}",
        "kind": "refactor_transaction_lifecycle",
        "bucket": "polishment"
      }
    ],
