        "before": "Aspects.of(app).add(new AwsSolutionsChecks());",
        "after": "Aspects.of(app).add(AwsSolutionsChecks.Builder.create().build());",
        "kind": "update_constructor_to_builder",
        "bucket": "breaking"
      },
      {
