      {
        "general_idea": "Upgrade Spring Boot parent version from 2.6.7 to 3.4.5 to align with Java 21 and modern Spring ecosystem.",
        "why_exists": "Spring Boot 2.x does not support Java 21 as a baseline and lacks Jakarta EE 9+ namespace support required for modern libraries.",
        "before": "<version>2.6.7</version>",
        "after": "<version>3.4.5</version>",
        "kind": "upgrade_spring_boot_parent",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update Java version property from 17 to 21 to target the new JDK.",
        "why_exists": "Compilation will fail or produce incompatible bytecode if the source/target levels remain at 17 while using Java 21 features or libraries.",
        "before": "<java.version>17</java.version>",
        "after": "<java.version>21</java.version>",
        "kind": "update_java_version_property",
        "bucket": "breaking"
      },
      {
        "general_idea": "Remove the --enable-preview compiler argument as preview features are no longer used or required.",
        "why_exists": "The --enable-preview flag is unnecessary for standard Java 21 compilation and may cause issues if not explicitly supported by the toolchain configuration.",
        "before": "<compilerArgs>--enable-preview</compilerArgs>",
        "after": "",
        "kind": "remove_preview_flag",
        "bucket": "breaking"
      },
      {
        "general_idea": "Remove the --enable-preview argument from the Surefire plugin configuration.",
        "why_exists": "Tests will fail to run if the JVM is invoked with --enable-preview but the code does not use preview features, or if the flag is invalid in the new context.",
