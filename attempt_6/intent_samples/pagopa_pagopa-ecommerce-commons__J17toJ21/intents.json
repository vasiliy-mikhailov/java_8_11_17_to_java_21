        "after": "",
        "kind": "remove_surefire_preview_flag",
        "bucket": "breaking"
      },
      {
        "general_idea": "Configure maven-compiler-plugin with explicit executions to handle annotation processor compilation order.",
        "why_exists": "Compilation fails due to circular dependency or missing class issues when annotation processors are compiled in the same pass as the code they process.",
        "before": "<configuration>\n                    <source>17</source>\n                    <target>17</target>\n                    <compilerArgs>--enable-preview</compilerArgs>\n                </configuration>",
        "after": "<executions>\n                    <execution>\n                        <id>default-compile</id>\n                        <configuration>\n                            <source>21</source>\n                            <target>21</target>\n                            <compilerArgs>-proc:none</compilerArgs>\n                            <includes>\n                                <include>\n                                    it/pagopa/ecommerce/commons/utils/warmup/annotationprocessor/WarmupAnnotationProcessor.java\n                                </include>\n                            </includes>\n                        </configuration>\n                    </execution>\n                    <execution>\n                        <id>compile-project</id>\n                        <phase>compile</phase>\n                        <goals>\n                            <goal>compile</goal>\n                        </goals>\n                        <configuration>\n                            <source>21</source>\n                            <target>21</target>\n                        </configuration>\n                    </execution>\n                </executions>\n                <configuration>\n                    <source>21</source>\n                    <target>21</target>\n                </configuration>",
        "kind": "configure_compiler_executions",
        "bucket": "breaking"
      },
