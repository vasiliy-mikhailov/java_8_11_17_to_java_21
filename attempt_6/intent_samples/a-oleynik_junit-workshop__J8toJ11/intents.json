    "pom.xml": [
      {
        "general_idea": "Update maven-compiler-plugin to support Java 11 compilation and use property-based versioning.",
        "why_exists": "Older maven-compiler-plugin versions may not fully support Java 11 language features or module system; explicit source/target 1.8 prevents compilation on JDK 11.",
        "before": "<artifactId>maven-compiler-plugin</artifactId>\n                <version>3.5.1</version>\n                <configuration>\n                    <source>1.8</source>\n                    <target>1.8</target>",
        "after": "<artifactId>maven-compiler-plugin</artifactId>\n                <version>3.10.1</version>\n                <configuration>\n                    <source>${java.version}</source>\n                    <target>${java.version}</target>",
        "kind": "update_compiler_plugin",
        "bucket": "breaking"
      },
      {
        "general_idea": "Replace JUnit 4 dependency with JUnit Jupiter Engine for JUnit 5 support.",
        "why_exists": "JUnit 4 API is not compatible with JUnit 5 test structure; tests using @Test from org.junit.jupiter.api will fail to compile or run without the Jupiter engine.",
        "before": "<groupId>junit</groupId>\n            <artifactId>junit</artifactId>\n            <version>4.12</version>",
        "after": "<groupId>org.junit.jupiter</groupId>\n            <artifactId>junit-jupiter-engine</artifactId>\n            <version>${junit-jupiter.version}</version>",
        "kind": "switch_junit_version",
        "bucket": "breaking"
      },
      {
        "general_idea": "Replace JUnitParams with JUnit Jupiter Params for parameterized tests.",
        "why_exists": "JUnitParams is a JUnit 4 extension; it is incompatible with JUnit 5 execution model and will cause runtime failures or compilation errors if used with JUnit 5 annotations.",
        "before": "<groupId>pl.pragmatists</groupId>\n            <artifactId>JUnitParams</artifactId>\n            <version>1.0.5</version>",
        "after": "<groupId>org.junit.jupiter</groupId>\n            <artifactId>junit-jupiter-params</artifactId>\n            <version>${junit-jupiter.version}</version>",
        "kind": "switch_param_provider",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update maven-surefire-plugin to version 3.x to support JUnit 5 execution.",
        "why_exists": "Surefire 2.x does not natively support JUnit 5 platform; tests will not be discovered or executed correctly without upgrading to Surefire 3.x.",
        "before": "<artifactId>maven-surefire-plugin</artifactId>\n                <version>2.19</version>\n                <dependencies>\n                    <dependency>\n                        <groupId>org.apache.maven.surefire</groupId>\n                        <artifactId>surefire-junit47</artifactId>\n                        <version>2.19</version>\n                    </dependency>\n                </dependencies>",
        "after": "<artifactId>maven-surefire-plugin</artifactId>\n                <version>3.1.2</version>",
        "kind": "update_surefire_plugin",
        "bucket": "breaking"
      },
      {
        "general_idea": "Migrate parallel test configuration from Surefire properties to JUnit Platform configuration parameters.",
