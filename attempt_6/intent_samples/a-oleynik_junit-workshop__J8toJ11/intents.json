        "before": "<parallel>classes</parallel>\n-                    <threadCount>3</threadCount>\n                     <properties>\n-<!--                        <property>\n-                            <name>listener</name>\n-                            <value>com.dataart.qa.workshop.junit.listeners.ExampleListener</value>\n-                        </property>-->",
        "after": "<properties>\n                        <configurationParameters>\n                            junit.jupiter.execution.parallel.enabled=true\n                            junit.jupiter.execution.parallel.mode.default=concurrent\n                        </configurationParameters>",
        "kind": "migrate_parallel_config",
        "bucket": "breaking"
      },
      {
