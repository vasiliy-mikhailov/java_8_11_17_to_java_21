        "after": "<version>3.2.2</version>",
        "kind": "upgrade_spring_boot_parent",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update Java version property from 11 to 21 to target the new JDK.",
        "why_exists": "Without this change, the compiler targets JDK 11, preventing the use of JDK 21 features and potentially causing runtime incompatibilities with libraries expecting JDK 21.",
        "before": "<java.version>11</java.version>",
        "after": "<java.version>21</java.version>",
        "kind": "update_java_version_property",
        "bucket": "breaking"
      },
