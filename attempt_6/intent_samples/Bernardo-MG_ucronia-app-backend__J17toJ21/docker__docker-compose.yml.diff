+  association-db:
+    image: postgres:15.0-alpine
+    environment:
+      PGUSER: 'postgres'
+      POSTGRES_DB: 'postgres'
+      POSTGRES_USER: 'postgres'
+      POSTGRES_PASSWORD: 'password'
+    ports:
+      - "127.0.0.1:5432:5432"
