    ".github/workflows/maven.yml": [
      {
        "general_idea": "Update the CI workflow to use JDK 21 instead of JDK 23 to align with the target migration version.",
        "why_exists": "",
        "before": "java-version: '23'",
        "after": "java-version: '21'",
        "kind": "update_jdk_version",
        "bucket": "polishment"
      },
      {
        "general_idea": "Modify the Maven build command to skip tests and include a clean phase.",
        "why_exists": "",
        "before": "run: mvn -B package -f backend/pom.xml",
        "after": "run: mvn -B clean package -DskipTests -f backend/pom.xml",
        "kind": "update_build_command",
        "bucket": "polishment"
      }
    ],
    ".gitignore": [],
