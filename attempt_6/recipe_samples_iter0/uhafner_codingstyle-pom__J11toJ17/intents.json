  "by_file": {
    "pom.xml": [
      {
        "general_idea": "Update the Java source and target version property from 11 to 17 to align with the migration target.",
        "why_exists": "Without this change, the project continues to compile against Java 11 language features and bytecode, failing to utilize or enforce Java 17 standards.",
        "before": "<java.version>11</java.version>",
        "after": "<java.version>17</java.version>",
        "kind": "update_java_version_property",
        "bucket": "breaking"
      },
      {
        "general_idea": "Migrate the annotation API dependency from the legacy javax namespace to the Jakarta namespace.",
        "why_exists": "Java 17 and modern Jakarta EE environments do not include javax.annotation by default; using the old groupId/artifactId may lead to missing classes or conflicts with Jakarta EE 9+ standards.",
        "before": "<groupId>javax.annotation</groupId>\n      <artifactId>javax.annotation-api</artifactId>",
        "after": "<groupId>jakarta.annotation</groupId>\n      <artifactId>jakarta.annotation-api</artifactId>",
        "kind": "migrate_javax_to_jakarta_annotation",
        "bucket": "breaking"
      },
      {
        "general_idea": "Add 'provided' scope to the Jakarta annotation API dependency.",
        "why_exists": "",
        "before": "<version>${javax.annotation-api.version}</version>",
        "after": "<version>${javax.annotation-api.version}</version>\n      <scope>provided</scope>",
        "kind": "add_dependency_scope",
        "bucket": "polishment"
      },
      {
        "general_idea": "Bump the version of the javax.annotation-api property to a newer patch release.",
        "why_exists": "",
