# Top-level orchestrator results (regenerated every run).
# Per-iteration results under iter-NNN/results/ ARE versioned — they're
# the trajectory the fitness contract calls a first-class output.
/results/
/ralph-run/
/real-ralph-run/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Local Maven/Gradle cache (if anyone runs the harness directly without Docker)
.m2/
.gradle/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Editor backups
*~
*.swp

# Local state files
/tmp/real-ralph-state.json
*.log

# Secrets — .env is the per-host config (vLLM endpoint + key). Never commit.
.env
attempt_3/verify/baseline/
