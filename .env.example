# Copy to .env and fill in for your environment. .env is gitignored.
# Per ff #5 + ff #11: every endpoint here MUST be auth-gated; no unauthenticated bind.

# Proposer endpoint (ff #1, ff #10). Tool-capable, OpenAI-compatible.
# Currently: Qwen 3.6 27B FP8 dense, served from item 5's vLLM stack.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=qwen3.6-27b-fp8
VLLM_API_KEY=sk-...

# Compactor endpoint (ff #7). Separate accelerator to avoid contention with proposer.
# Currently: Qwen 3.6 27B AWQ INT4 dense, served from item 5's vLLM stack.
COMPACTOR_VLLM_BASE_URL=http://localhost:8001/v1
COMPACTOR_VLLM_MODEL=qwen3.6-27b-awq
COMPACTOR_VLLM_API_KEY=sk-...

# Investigator subagent framework (ff #11). OpenHands instance, basic-auth protected.
# Authoritative deployment for this project: https://openhands.mikhailov.tech
OPENHANDS_BASE_URL=https://openhands.mikhailov.tech
OPENHANDS_USER=...
OPENHANDS_PASS=...

# Local Maven artifact proxy admin (ff #3). Nexus.
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=...
